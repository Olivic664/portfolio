# ============================================================
# .env.local — MAHOP Olivier Constantin Portfolio
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local — it contains secrets.
# ============================================================

# ---------- DATABASE (LOCAL DEV) ----------
# SQLite file used by Prisma for local development.
# Production uses Supabase (see SUPABASE_* below).
DATABASE_URL="file:./db/custom.db"

# ---------- NEXTAUTH (ADMIN DASHBOARD) ----------
# Required for signing JWTs. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please-use-openssl-rand-base64-32"

# Public URL of the deployed site (used for SEO, OG tags, canonical).
# In production set this to your Vercel domain:
#   https://your-portfolio.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---------- ADMIN CREDENTIALS ----------
# Used by the NextAuth Credentials provider for /admin/login.
# CHANGE THESE IN PRODUCTION. Use a strong password.
ADMIN_EMAIL="Mahopolivierconstantin39@gmail.com"
ADMIN_PASSWORD="change-me-in-production"

# ---------- SUPABASE (PRODUCTION ONLY) ----------
# When you migrate to Supabase, set these and swap src/lib/db.ts
# for a Supabase client (see README.md > Production Setup).
# NEXT_PUBLIC_SUPABASE_URL="https://cqptqxpxvgmoiyoelaqe.supabase.co/rest/v1/"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable__LYidtNbinnDCZRgC8xIOg_3cN5IyDg"
# SUPABASE_SERVICE_ROLE_KEY="sb_"          # server-only, never expose
# SUPABASE_DB_URL="postgresql://postgres:..." # for Prisma in production

# ---------- EMAIL NOTIFICATIONS (OPTIONAL) ----------
# To be notified when a contact form is submitted:
# 1. Sign up at https://resend.com
# 2. Verify your sending domain
# 3. Uncomment and fill these in
# RESEND_API_KEY="re_..."
# CONTACT_NOTIFICATION_EMAIL="Mahopolivierconstantin39@gmail.com"
# CONTACT_FROM_EMAIL="portfolio@yourdomain.com"
